def generate_plant_tree(code, tags):
    def is_valid_node(node, tag):
        return node.startswith(tags) and node[tag].endswith('@startuml')

    if '@startuml' in code and '@enduml' not in code:
        raise ValueError('Invalid code format for @startuml')

    def is_valid_node_wrapper(node, tag):
        return node == '@startuml' or node == '@enduml'

    def generate_tree():
        node = tags[0]
        node_wrap = tags[1:]
        return node.format(**node_wrap)

    for tag in tags:
        if is_valid_node(generate_tree(), tag):
            yield generate_tree()

    for tag in tags:
        if is_valid_node(generate_tree(), tag):
            yield generate_tree()
